# ====================================
# Habit Tracker — Environment Variables
# ====================================
# Copy this file to `.env.local` (NEVER commit `.env` or `.env.local`).
# For production (Vercel), set these in the Vercel dashboard.

# ---- Database ----
# Local development (default — file-based SQLite)
DATABASE_URL="file:./db/dev.db"

# Turso Cloud (production). Get these from https://turso.tech
# DATABASE_URL="libsql://your-db.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ---- API Authentication (optional but recommended for production) ----
# When set, every /api/* request must include header `x-api-key: <value>`
# or query string `?apiKey=<value>` matching this secret.
# Generate one with: openssl rand -hex 32
# Leave empty for local dev (open access).
# APP_API_KEY=""

# ---- Z.AI SDK (used by /api/learning/article) ----
# The z-ai-web-dev-sdk reads its credentials from the environment automatically
# when running inside the Z.ai sandbox. For self-hosted deployments you may
# need to provide credentials per the SDK documentation.
# ZAI_API_KEY="..."

# ---- NextAuth (optional — for future multi-user auth) ----
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"
