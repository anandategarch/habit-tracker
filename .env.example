# ====================================
# Habit Tracker Professional V2
# Environment Variables
# ====================================

# ---- Database ----
# Option 1: Local SQLite (development / default)
DATABASE_URL="file:./db/dev.db"

# Option 2: Turso Cloud (production - set in Vercel dashboard)
# DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"
# DIRECT_URL="file:./db/dev.db"  (only needed for local migrations)