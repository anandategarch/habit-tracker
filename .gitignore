# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit secrets — use .env.local or your host's dashboard)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
server.log

# Database files
/db/*.db
/db/*.db-journal
*.sqlite
*.sqlite3

# Lockfiles — keep only bun.lock (we use bun as primary package manager)
package-lock.json
yarn.lock
pnpm-lock.yaml

# AI assistant working artifacts
agent-ctx/
worklog.md
.cache/
.zscripts/*.pid

# Screenshots & dev notes (should not be in version control)
*.png
*.jpg
*.jpeg
*.gif
*.webp
!public/**
dashboard-check.txt
final-check.txt
github-*.txt
migrate-*.txt
sources-check.txt
tx-check.txt
vercel-check.txt
panduan-deploy*.html
panduan-deploy*.pdf

# Skills directory
/skills/
# Tool results
tool-results/
upload/
